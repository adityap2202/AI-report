      "CF IS": {"type":"financial_statement","statement":"income_statement"},
      "CF CFS": {"type":"financial_statement","statement":"cash_flow"},
      "Borrowings": {"type":"note_rollup","topic":"borrowings"},
      "PPE": {"type":"note_rollup","topic":"ppe"},
      "Revenue & OI": {"type":"note_rollup","topic":"revenue"},
      "Expenses": {"type":"note_rollup","topic":"expenses"},
      "Working capital": {"type":"note_rollup","topic":"working_capital"}
    }
  }